# 再取得可能な外部データ（数 MB あるので追跡しない）
data/problem-models.json
data/problems.json
data/contest-problem.json

# 生成物。build_vault.py が data/ からいつでも作り直せる派生物なので追跡しない。
# 追跡すると data/code のコードを二重管理することになり、タグ体系を変えるたびに
# 1,716 ファイルぶんの diff が出てレビューが読めなくなる。
vault/problems/

# Obsidian のローカル状態。設定（vault/.obsidian/）そのものは data/ から再生成できない
# 唯一の資産なので追跡する。M4 の Dataview 設定がここに入る。
vault/.obsidian/workspace*
vault/.obsidian/cache
vault/.trash/

# M3 のバッチプロンプト。batch_tags.py が data/ からいつでも作り直せる派生物。
# 追跡すると 1,070 問ぶんのコードを二重管理することになる。
build/

__pycache__/
*.pyc
.venv/
